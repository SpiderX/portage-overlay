	ego build -o dist/tflint
}

src_test() {
	mapfile -t pkgs < <( ego list ./... | grep -Ev '/(test-fixtures|stub-generator|integrationtest)' )
	ego test -timeout 5m -skip 'Test_Discovery|Test_FindPluginPath|TestLoadConfig' "${pkgs[@]}"
}

src_install() {
	einstalldocs
	dobin dist/tflint
}
